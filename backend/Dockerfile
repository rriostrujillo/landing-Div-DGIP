FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci --only=production

# Copy source
COPY src/ ./src/
COPY public/ ./public/
COPY docs/ ./docs/
COPY .env.production ./.env

# Create uploads directory
RUN mkdir -p uploads

# Expose port
EXPOSE 3000

# Start
CMD ["npm", "start"]